<h2><%= email.object %></h2>
<p><%= email.body %></p>

<div class="mt-3">
  <!-- Boutons inactifs pour le moment -->
  <%= button_to "Supprimer", email_path(email), method: :delete, class: "btn btn-danger" %>
  <% if email.read %>
    <%= button_to "Marquer comme non-lu", email_path(email, email: { read: false }), method: :patch, class: "btn btn-secondary" %>
  <% else %>
    <%= button_to "Marquer comme lu", email_path(email, email: { read: true }), method: :patch, class: "btn btn-success" %>
  <% end %>
</div>
